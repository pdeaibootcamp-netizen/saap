# ============================================================
# Strategy Radar — environment variables template
# Copy to .env.local for local dev. NEVER commit .env.local.
# ============================================================

# Supabase Postgres connection string (D-013 / ADR-0002-A).
# Use the pooler endpoint (port 6543) for Vercel serverless functions;
# use the direct endpoint (port 5432) for migrations (supabase db push).
# Format: postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Supabase project URL and anon key — used by @supabase/ssr for server-side
# cookie-based sessions (owner web view auth).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service-role key — used only in server-side API routes for admin
# operations (analyst brief publish). NEVER exposed to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Resend API key — used for transactional email delivery (ADR-0001-B).
# Only read by server-side API routes — never exposed to the browser.
RESEND_API_KEY=

# George Business JWT secret — used to validate the signed token arriving in
# the ?token= query parameter from the George Business redirect (ADR-0001-E).
# Must match the signing key on the ČS side.
GEORGE_JWT_SECRET=

# Analyst admin password — hashed bcrypt value used by Next.js middleware to
# protect the /admin/* route group (ADR-0001-D).
# Generate with: node -e "require('crypto').scryptSync('yourpassword','salt',32).toString('hex')"
# Or use a proper bcrypt hash. The middleware validates against this value.
ADMIN_PASSWORD_HASH=

# Vercel Blob token — used for PDF storage (ADR-0002-F).
# Automatically set by Vercel when Blob storage is provisioned; set manually for local dev.
BLOB_READ_WRITE_TOKEN=

# n8n Cloud webhook URL (workspace kappa3). POST target for new analysis jobs.
# docs/engineering/n8n-integration.md §4
N8N_WEBHOOK_URL=

# HMAC-SHA256 shared secret — orchestrator app → n8n direction.
# Set the matching value in the n8n workflow's webhook node (Header Auth).
N8N_WEBHOOK_SECRET=

# HMAC-SHA256 shared secret — n8n → orchestrator callback direction.
# Set in the n8n workflow's HTTP Request node that calls /api/admin/briefs/from-n8n.
N8N_CALLBACK_SECRET=

# Enable demo-mode endpoints (POST /api/owner/demo/switch and /reset).
# Must be 'true' explicitly; any other value (including unset) disables these routes.
# docs/engineering/owner-metrics-api.md ADR-OM-03
DEMO_MODE=

# Feature flags for v0.3 data backends.
# Set to 'false' to fall back to v0.2 in-memory fixtures (safe default during transition).
USE_REAL_COHORT_DATA=true
USE_REAL_OWNER_METRICS=true
