{
  "name": "strategy-radar",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "supabase db push",
    "db:generate": "supabase gen types typescript --local > src/types/supabase.ts",
    "seed": "tsx --env-file=.env.local scripts/seed.ts"
  },
  "dependencies": {
    "next": "14.2.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "postgres": "^3.4.4",
    "@supabase/supabase-js": "^2.44.2",
    "@supabase/ssr": "^0.4.0",
    "jose": "^5.6.2",
    "puppeteer": "^23.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.5.3",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.4",
    "vitest": "^1.6.0",
    "@vitejs/plugin-react": "^4.3.1",
    "vite-tsconfig-paths": "^4.3.2",
    "supabase": "^1.178.2",
    "tsx": "^4.7.0"
  }
}
